<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="14dp"
    android:background="@color/notification_bg">

    <!-- App Icon (left) -->
    <ImageView
        android:id="@+id/notification_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@mipmap/ic_launcher"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="12dp"
        android:contentDescription="App Icon" />

    <!-- Right: Mosque Image -->
    <ImageView
        android:id="@+id/notification_mosque_image"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@mipmap/ic_launcher"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:contentDescription="Mosque" />

    <!-- Center: Prayer info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notification_icon"
        android:layout_toStartOf="@id/notification_mosque_image"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:layout_marginEnd="10dp">

        <!-- Label: "الصلاة القادمة" -->
        <TextView
            android:id="@+id/notification_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الصلاة القادمة"
            android:textColor="@color/text_sub"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            android:layout_gravity="end" />

        <!-- Prayer name (large, green) -->
        <TextView
            android:id="@+id/notification_prayer_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الظهر"
            android:textColor="@color/notification_primary"
            android:textStyle="bold"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="end"
            android:layout_marginTop="1dp" />

        <!-- Timer badge row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <!-- "الوقت المتبقي" label -->
            <TextView
                android:id="@+id/notification_timer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الوقت المتبقي"
                android:textColor="@color/text_sub"
                android:textSize="10sp"
                android:layout_marginEnd="6dp" />

            <!-- Timer badge pill (orange) -->
            <TextView
                android:id="@+id/notification_time_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 د"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/timer_badge_bg"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden field to pass the full title (used for plugin internal logic) -->
    <TextView
        android:id="@+id/notification_title"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:text="الرسالة" />

</RelativeLayout>
